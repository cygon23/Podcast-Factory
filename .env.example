# Dorosak Podcast Factory - environment variables.
#
# Copy to .env and fill in only what you need for the engine(s) you intend
# to use. Nothing here is required to run the test suite or a --dry-run;
# the auto-detection chain (see docs/README.md) checks these in order and picks the
# first engine that's fully configured.

# --- Kokoro (local, $0, no API key) --------------------------------------
# Install the `kokoro` package and download hexgrad/Kokoro-82M yourself
# (see docs/OPERATOR_TODO.md step 4 for the full walkthrough) - this
# project never downloads models. All three paths below are required.
KOKORO_MODEL_PATH=
KOKORO_CONFIG_PATH=
KOKORO_VOICES_DIR=

# --- Azure Cognitive Services Speech --------------------------------------
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# --- OpenAI ----------------------------------------------------------------
OPENAI_API_KEY=

# --- Google Cloud Text-to-Speech -------------------------------------------
# Path to a service-account JSON key file (not the key contents).
GOOGLE_APPLICATION_CREDENTIALS=

# --- Amazon Polly ------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- ElevenLabs --------------------------------------------------------------
# Voice IDs are account-specific - you must also set tts.voice_map.elevenlabs
# in config.yaml before this engine can be used (see docs/ASSETS.md).
ELEVENLABS_API_KEY=
